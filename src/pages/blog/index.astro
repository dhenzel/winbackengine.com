---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import BlogFooter from '../../components/BlogFooter.astro';
import { BOOKING_URL } from '../../config';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog | Winback Engine" description="Customer reactivation strategies, churn benchmarks, and growth playbooks for multi-location service businesses.">
  <Header />
  <div class="h-16 sm:h-20"></div>

  <section class="py-12 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12 sm:mb-16 text-center">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-4">
          The Winback Engine <span class="text-accent-green">Blog</span>
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
          Strategies, benchmarks, and playbooks for recovering lapsed customers and reducing churn in multi-location service businesses.
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="group block bg-navy-800/30 border border-white/5 rounded-2xl overflow-hidden hover:border-accent-green/20 transition-colors">
            {post.data.image && (
              <div class="aspect-[16/9] overflow-hidden">
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
            )}
            <div class="p-6">
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="text-xs font-medium text-accent-green bg-accent-green/10 px-2 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
              )}
              <h2 class="text-lg font-bold text-white group-hover:text-accent-green transition-colors mb-2 leading-snug">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-400 line-clamp-2 mb-4">{post.data.description}</p>
              <div class="text-xs text-gray-500">
                <time datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <BlogFooter />
</Layout>

---
const stats = [
  { value: "500+", label: "Team Members" },
  { value: "8+", label: "Countries" },
  { value: "8+", label: "Years in Business" },
  { value: "100+", label: "Clients Served" },
];

const certifications = [
  { src: "/logos/iso-badge.jpeg", alt: "ISO 27001:2022 Certified", label: "ISO 27001:2022" },
  { src: "/logos/great-place-to-work.svg", alt: "Great Place to Work Certified", label: "Great Place to Work" },
  { src: "/logos/top-bpo-clutch.png", alt: "Top Clutch BPO Company 2024", label: "Top 500 Global BPO" },
];
---

<section class="py-20 sm:py-28 bg-navy-800/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="flex justify-center mb-6">
        <img src="/logos/ltvplus-logo-white.png" alt="LTVplus" class="h-10 sm:h-12" />
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        Powered by <span class="text-accent-green">LTVplus</span>
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        You're not hiring a startup. You're getting a dedicated team from a proven global operation.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {stats.map((stat) => (
        <div class="bg-navy-900/50 border border-white/5 rounded-xl p-6 text-center">
          <div class="text-3xl font-extrabold text-white">{stat.value}</div>
          <div class="text-sm text-gray-400 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>

    <div class="flex flex-wrap justify-center items-center gap-8 sm:gap-12">
      {certifications.map((cert) => (
        <div class="flex flex-col items-center gap-2">
          <img src={cert.src} alt={cert.alt} class="h-16 sm:h-20 object-contain" />
          <span class="text-xs text-gray-500 font-medium">{cert.label}</span>
        </div>
      ))}
      <div class="flex flex-col items-center gap-2">
        <div class="h-16 sm:h-20 flex items-center justify-center px-4 bg-navy-900/50 border border-white/10 rounded-xl">
          <span class="text-2xl sm:text-3xl font-extrabold text-accent-green">95%+</span>
        </div>
        <span class="text-xs text-gray-500 font-medium">Client Satisfaction</span>
      </div>
    </div>
  </div>
</section>

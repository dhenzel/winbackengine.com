---
const steps = [
  {
    number: "1",
    title: "Connect Your Data",
    description: "Import your customer list or connect your CRM (Zenoti, Mindbody, Vagaro, and more). We identify who's lapsed and most likely to return.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
  },
  {
    number: "2",
    title: "We Build Your Campaigns",
    description: "Lapsed customer callbacks, birthday outreach, refer-a-friend. Tailored scripts, smart timing, human review.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>`,
  },
  {
    number: "3",
    title: "Real People Make Real Calls",
    description: "Trained agents pick up the phone. Every call recorded. Customers rebook, renew, or buy gift cards.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>`,
  },
];
---

<section id="how-it-works" class="py-20 sm:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        How It Works
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        Three simple steps. No software to learn. No AI. Just results.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step) => (
        <div class="relative bg-navy-800/50 border border-white/5 rounded-2xl p-8 hover:border-accent-green/20 transition-colors">
          <div class="flex items-center justify-center w-14 h-14 bg-accent-green/10 text-accent-green rounded-xl mb-6">
            <Fragment set:html={step.icon} />
          </div>
          <div class="absolute top-6 right-6 text-5xl font-extrabold text-white/5">{step.number}</div>
          <h3 class="text-xl font-bold mb-3">{step.title}</h3>
          <p class="text-gray-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
const LOGO_TOKEN = "pk_XXWbiTGwTfGmkCFPKmOXKg";

const platforms = [
  { name: "Zenoti", domain: "zenoti.com" },
  { name: "Mindbody", domain: "mindbodyonline.com" },
  { name: "Vagaro", domain: "vagaro.com" },
  { name: "WellnessLiving", domain: "wellnessliving.com" },
  { name: "Booker", domain: "booker.com" },
  { name: "Fresha", domain: "fresha.com" },
  { name: "Phorest", domain: "phorest.com" },
  { name: "MarianaTek", domain: "marianatek.com" },
];
---

<section class="py-20 sm:py-28 bg-navy-800/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        We Integrate With Your <span class="text-accent-green">Current Platforms</span>
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        Connect your existing CRM or booking software. We pull lapsed customer data automatically — no migration, no manual exports.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-4xl mx-auto">
      {platforms.map((platform) => (
        <div class="bg-navy-900/50 border border-white/5 rounded-xl p-5 flex flex-col items-center gap-3 hover:border-accent-green/20 transition-colors">
          <img
            src={`https://img.logo.dev/${platform.domain}?token=${LOGO_TOKEN}&format=png`}
            alt={platform.name}
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
          <div class="text-sm font-semibold text-white">{platform.name}</div>
        </div>
      ))}
    </div>

    <p class="text-center text-gray-500 text-sm mt-8">
      Don't see your platform? We integrate with any system that exports customer data — CSV, API, or direct connection.
    </p>
  </div>
</section>

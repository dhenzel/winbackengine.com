---
const platforms = [
  { name: "Zenoti", category: "Spa & Salon" },
  { name: "Mindbody", category: "Fitness & Wellness" },
  { name: "Vagaro", category: "Beauty & Wellness" },
  { name: "WellnessLiving", category: "Studio Management" },
  { name: "Booker", category: "Spa & Salon" },
  { name: "Fresha", category: "Beauty" },
  { name: "Phorest", category: "Salon" },
  { name: "MarianaTek", category: "Boutique Fitness" },
];
---

<section class="py-20 sm:py-28 bg-navy-800/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        We Integrate With Your <span class="text-accent-green">Current Platforms</span>
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        Connect your existing CRM or booking software. We pull lapsed customer data automatically — no migration, no manual exports.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-4xl mx-auto">
      {platforms.map((platform) => (
        <div class="bg-navy-900/50 border border-white/5 rounded-xl p-5 text-center hover:border-accent-green/20 transition-colors">
          <div class="text-lg font-bold text-white mb-1">{platform.name}</div>
          <div class="text-xs text-gray-500">{platform.category}</div>
        </div>
      ))}
    </div>

    <p class="text-center text-gray-500 text-sm mt-8">
      Don't see your platform? We integrate with any system that exports customer data — CSV, API, or direct connection.
    </p>
  </div>
</section>

---
import { BOOKING_URL } from '../config';
---

<section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy-800/50 to-navy-900"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-accent-green/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-block text-xs sm:text-sm font-semibold text-accent-green bg-accent-green/10 px-4 py-1.5 rounded-full uppercase tracking-wider mb-6">
      For Multi-Location Franchises and Service Chains
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold tracking-tight leading-[1.1] max-w-5xl mx-auto">
      Your lapsed customers are leaving money on the table.
      <span class="text-accent-green"> We call them back.</span>
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
      Trained human agents call your lapsed customers and get them to rebook.
      3x ROI guaranteed — or you don't pay.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={BOOKING_URL}
        class="inline-flex items-center px-8 py-4 bg-accent-green hover:bg-accent-green-light text-navy-900 font-bold rounded-xl transition-colors text-lg"
      >
        Book a Strategy Call
      </a>
      <a
        href="#how-it-works"
        class="inline-flex items-center px-8 py-4 border border-white/20 hover:border-white/40 text-white font-semibold rounded-xl transition-colors text-lg"
      >
        See How It Works
      </a>
    </div>
  </div>
</section>

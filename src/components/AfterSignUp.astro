---
const steps = [
  {
    number: "1",
    day: "Day 1",
    title: "CRM Connect & Data Import",
    description: "We connect to your CRM (Zenoti, Mindbody, Vagaro, etc.) and pull your lapsed customer data. Same day.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.813a4.5 4.5 0 00-6.364-6.364L4.5 8.25l4.5 4.5" /></svg>`,
  },
  {
    number: "2",
    day: "Days 2–3",
    title: "Campaign Design & Scripting",
    description: "We build customer segments, call scripts, objection handling, and offer strategy — tailored to your business and vertical.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" /></svg>`,
  },
  {
    number: "3",
    day: "Days 4–5",
    title: "Agent Training & Calibration",
    description: "Your dedicated agent learns your brand, services, and customer profile. Test calls, feedback loops, and refinement before going live.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
  },
  {
    number: "4",
    day: "Day 6+",
    title: "Calls Start, Revenue Flows",
    description: "Your agent starts calling. Customers rebook. You see results in your CRM and our daily reports. Every call recorded and reviewable.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`,
  },
];
---

<section class="py-20 sm:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        What Happens <span class="text-accent-green">After You Sign Up</span>
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        From sign-up to first results in under a week. Here's the timeline.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {steps.map((step) => (
        <div class="relative bg-navy-800/50 border border-white/5 rounded-2xl p-8 hover:border-accent-green/20 transition-colors">
          <div class="absolute top-6 right-6 text-5xl font-extrabold text-white/5">{step.number}</div>
          <div class="flex items-center justify-center w-12 h-12 bg-accent-green/10 text-accent-green rounded-xl mb-4">
            <Fragment set:html={step.icon} />
          </div>
          <div class="text-xs font-semibold text-accent-green uppercase tracking-wider mb-2">{step.day}</div>
          <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

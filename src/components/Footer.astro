    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="text-lg font-extrabold tracking-tight">
          <span class="text-white">Winback</span><span class="text-accent-green">Engine</span>
        </span>
        <span class="text-gray-500 text-sm">by LTVplus</span>
      </div>
      <div class="text-sm text-gray-500">
        &copy; {year} WinbackEngine. All rights reserved.
      </div>
    </div>
  </div>
</footer>

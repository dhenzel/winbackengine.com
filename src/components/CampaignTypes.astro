---

<section class="py-20 sm:py-28 bg-navy-800/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
        Campaigns That <span class="text-accent-green">Drive Revenue</span>
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        Dynamic segments, smart timing, and trained agents — every campaign adapts daily to your business.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {campaigns.map((campaign) => (
        <div class="bg-navy-900/50 border border-white/5 rounded-2xl p-6 hover:border-accent-green/20 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex items-center justify-center w-10 h-10 bg-accent-green/10 text-accent-green rounded-lg">
              <Fragment set:html={campaign.icon} />
            </div>
            <h3 class="text-lg font-bold">{campaign.title}</h3>
          </div>
          <p class="text-gray-400 text-sm leading-relaxed">{campaign.description}</p>
        </div>
      ))}
    </div>

    <p class="text-center text-gray-500 text-sm mt-8">
      These are examples — every campaign is customized to your business, your customers, and your goals.
    </p>
  </div>
</section>
